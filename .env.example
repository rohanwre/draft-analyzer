# Copy this file to .env and fill in real values.
# In production (Railway/Render), set these as environment variables in the
# platform's dashboard instead of committing a .env file.

DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=fantasy_draft_analyzer

# Comma-separated list of frontend origins allowed to call this API.
# Include your deployed Vercel URL once you have one, e.g.:
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
